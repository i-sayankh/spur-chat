# PostgreSQL connection string (Neon in prod — include sslmode=require).
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# OpenAI API key.
OPENAI_API_KEY=sk-...

# OpenAI model (optional — defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Port the server listens on (host-provided in prod).
PORT=8080

# Allowed CORS origin (the frontend URL). Use * only in local dev.
CORS_ORIGIN=http://localhost:5173
